generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

enum DownloadJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  phone        String?       @unique
  createdAt    DateTime      @default(now())
  selfies      UserSelfie[]
  matchResults MatchResult[]
  downloads    DownloadJob[]

  @@index([createdAt])
}

model Event {
  id          String      @id @default(cuid())
  name        String
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime    @default(now())
  selfies     UserSelfie[]
  photos      Photo[]
  photoFaces  PhotoFace[]
  matchResult MatchResult[]
  downloads   DownloadJob[]

  @@index([startsAt])
  @@index([createdAt])
}

model UserSelfie {
  id                String           @id @default(cuid())
  userId            String
  eventId           String
  s3Bucket          String
  s3Key             String
  status            ProcessingStatus @default(PENDING)
  rekognitionFaceId String?
  errorMessage      String?          @db.VarChar(1024)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, status])
  @@index([userId, createdAt])
}

model Photo {
  id           String           @id @default(cuid())
  eventId      String
  s3Bucket     String
  s3Key        String
  thumbnailS3Key String?
  previewS3Key String?
  status       ProcessingStatus @default(PENDING)
  errorMessage String?          @db.VarChar(1024)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faces        PhotoFace[]
  matches      MatchResult[]

  @@unique([eventId, s3Key])
  @@index([eventId, status])
  @@index([eventId, createdAt])
}

model DownloadJob {
  id               String          @id @default(cuid())
  userId           String
  eventId          String
  selectedPhotoIds Json
  status           DownloadJobStatus @default(PENDING)
  s3Bucket         String?
  s3Key            String?
  errorMessage     String?          @db.VarChar(1024)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event            Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, eventId, createdAt])
  @@index([eventId, status])
}

model PhotoFace {
  id                String    @id @default(cuid())
  photoId           String
  eventId           String
  rekognitionFaceId String?
  boundingBox       Json?
  confidence        Float
  createdAt         DateTime  @default(now())
  photo             Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([photoId, rekognitionFaceId])
  @@index([eventId, rekognitionFaceId])
  @@index([photoId, createdAt])
}

model MatchResult {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  photoId    String
  similarity Float
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, photoId])
  @@index([userId, eventId, createdAt])
  @@index([eventId, similarity])
}
