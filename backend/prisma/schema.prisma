generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum ProcessingStatus {
  PENDING
  PROCESSED
  FAILED
}

enum DownloadJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EventType {
  MARRIAGE
  BIRTHDAY
  CORPORATE
  OTHER
}

enum GuestSide {
  BRIDE
  GROOM
}

enum VideoUploadStatus {
  INITIATED
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  email        String?       @unique
  phone        String?       @unique
  createdAt    DateTime      @default(now())
  selfies      UserSelfie[]
  matchResults MatchResult[]
  downloads    DownloadJob[]
  eventGuests  EventGuest[]
  videoMatches VideoFaceMatch[]

  @@index([createdAt])
}

model Event {
  id          String      @id @default(cuid())
  name        String
  eventType   EventType
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime    @default(now())
  selfies     UserSelfie[]
  photos      Photo[]
  photoFaces  PhotoFace[]
  matchResult MatchResult[]
  downloads   DownloadJob[]
  guests      EventGuest[]
  videos      VideoUpload[]
  videoMatches VideoFaceMatch[]

  @@index([startsAt])
  @@index([createdAt])
}

model EventGuest {
  id         String    @id @default(cuid())
  userId     String
  eventId    String
  fullName   String
  phone      String
  side       GuestSide?
  relation   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, phone])
  @@index([eventId, createdAt])
}

model UserSelfie {
  id                String           @id @default(cuid())
  userId            String
  eventId           String
  s3Bucket          String
  s3Key             String
  status            ProcessingStatus @default(PENDING)
  rekognitionFaceId String?
  errorMessage      String?          @db.VarChar(1024)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId, status])
  @@index([userId, createdAt])
}

model Photo {
  id           String           @id @default(cuid())
  eventId      String
  s3Bucket     String
  s3Key        String
  thumbnailS3Key String?
  previewS3Key String?
  status       ProcessingStatus @default(PENDING)
  errorMessage String?          @db.VarChar(1024)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  faces        PhotoFace[]
  matches      MatchResult[]

  @@unique([eventId, s3Key])
  @@index([eventId, status])
  @@index([eventId, createdAt])
}

model DownloadJob {
  id               String          @id @default(cuid())
  userId           String
  eventId          String
  selectedPhotoIds Json
  status           DownloadJobStatus @default(PENDING)
  s3Bucket         String?
  s3Key            String?
  errorMessage     String?          @db.VarChar(1024)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event            Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId, eventId, createdAt])
  @@index([eventId, status])
}

model PhotoFace {
  id                String    @id @default(cuid())
  photoId           String
  eventId           String
  rekognitionFaceId String?
  boundingBox       Json?
  confidence        Float
  createdAt         DateTime  @default(now())
  photo             Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([photoId, rekognitionFaceId])
  @@index([eventId, rekognitionFaceId])
  @@index([photoId, createdAt])
}

model MatchResult {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  photoId    String
  similarity Float
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, photoId])
  @@index([userId, eventId, createdAt])
  @@index([eventId, similarity])
}

model VideoUpload {
  id               String            @id @default(cuid())
  eventId          String
  s3Bucket         String
  s3Key            String
  originalFileName String
  contentType      String
  sizeBytes        BigInt
  durationSeconds  Int
  status           VideoUploadStatus @default(INITIATED)
  rekognitionJobId String?
  thumbnailS3Key   String?
  errorMessage     String?           @db.VarChar(1024)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  matches          VideoFaceMatch[]

  @@unique([eventId, s3Key])
  @@index([eventId, status])
  @@index([eventId, createdAt])
}

model VideoFaceMatch {
  id             String      @id @default(cuid())
  videoUploadId  String
  eventId        String
  userId         String
  timestampMs    Int
  similarity     Float
  boundingBox    Json?
  thumbnailS3Key String?
  clipS3Key      String?
  createdAt      DateTime    @default(now())
  videoUpload    VideoUpload  @relation(fields: [videoUploadId], references: [id], onDelete: Cascade)
  event          Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, userId, createdAt])
  @@index([videoUploadId, similarity])
}
