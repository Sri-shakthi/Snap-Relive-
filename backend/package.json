    "@aws-sdk/client-sqs": "^3.876.0",
    "@aws-sdk/s3-request-presigner": "^3.876.0",
    "@prisma/client": "^7.0.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "jszip": "^3.10.1",
    "joi": "^17.13.3",
    "mariadb": "^3.4.5",
    "morgan": "^1.10.0",
    "sharp": "^0.33.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0"
