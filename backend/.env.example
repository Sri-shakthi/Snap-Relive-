NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=
LOG_LEVEL=info

DATABASE_URL=mysql://root:root@localhost:3306/snapshots
DB_POOL_MAX=30

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=snapshots-dev-bucket
AWS_S3_PRESIGN_EXPIRES=900
AWS_S3_GET_EXPIRES=86400
AWS_S3_TRANSFER_ACCELERATION=false
CLOUDFRONT_BASE_URL=

REKOGNITION_COLLECTION_PREFIX=snapshots-event-

QUEUE_PROVIDER=memory
QUEUE_BACKPRESSURE_THRESHOLD=100
QUEUE_MAX_ATTEMPTS=5
QUEUE_RETRY_BASE_MS=500
AWS_SQS_QUEUE_URL=
AWS_SQS_WHATSAPP_QUEUE_URL=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

REMATCH_DEBOUNCE_MS=5000
REMATCH_BATCH_SIZE=25
MATCH_REFRESH_COOLDOWN_MS=15000
MATCH_REFRESH_BURST_LIMIT=3
VIDEO_REKOGNITION_POLL_DELAY_SECONDS=30
VIDEO_REKOGNITION_MAX_POLLS=120
FFMPEG_PATH=ffmpeg

WHATSAPP_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BASE_URL=https://graph.facebook.com
WHATSAPP_TEXT_TEMPLATE=Hi {{name}}, your SnapShots gallery is ready. Open {{appLink}} to view and download your photos.
FRONTEND_BASE_URL=http://localhost:5173
